# Local config overrides
prj_local.conf
*.local.overlay

# Large local-only reference bundles (hardware files, Nordic SDK binaries).
# Redistributable from Nordic — keep out of the repo to avoid bloat.
nordic resources/

# Per-user Claude Code settings (agent/skill configs etc. stay in .claude/
# at the project level, but local overrides and permissions are user-specific).
.claude/settings.local.json

# Default output directory for tools/pull_sessions.py. Per-run capture
# artifacts, keyed by UUID — no value checking them into the repo.
sessions/

# Canonical capture-archive location (GOSTEADY_CONTEXT.md "Post-Session
# Ingest" step 2). Dated subdirectories hold the raw .dat files plus
# the POST-WALK notes sidecar and any per-run log rotations. Bulk
# binary data — keep out of git entirely.
raw_sessions/

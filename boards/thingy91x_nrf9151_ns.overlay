/*
 * GoSteady board overlay for thingy91x/nrf9151/ns.
 *
 * Milestone 2 brings up the two motion sensors. Both sensor nodes are
 * defined but marked `disabled` in the upstream Thingy:91 X board DTS,
 * so we just flip their status to `okay` here. Bus wiring, register
 * addresses, max SPI frequency, and IRQ GPIOs all come from the board
 * DTS — no changes needed.
 *
 * - accelerometer_hp  = BMI270 (6-axis, SPI on spi3 CS2 = P0.10, IRQ P0.06)
 * - accel             = ADXL367 (3-axis LP, I2C on i2c2 @ 0x1d, INT1 P0.11)
 */

&accelerometer_hp {
	status = "okay";
};

&accel {
	status = "okay";
	/*
	 * Phase 1a (M14-prep) wake-on-motion: route the chip's INT1 line
	 * to P0.11 so the Zephyr ADXL367 driver can register a trigger
	 * callback. Pin / polarity match the GoSteady context note
	 * ("INT1 P0.11 active-high"). Without this property the trigger
	 * Kconfigs (CONFIG_ADXL367_TRIGGER_*) won't compile in.
	 */
	int1-gpios = <&gpio0 11 GPIO_ACTIVE_HIGH>;
};

/*
 * Milestone 5: route the nRF9151 uart1 (1 Mbaud, already pinctrl'd in
 * the board DTS) to the firmware. The nRF5340 connectivity bridge
 * already forwards this UART to the second USB-CDC endpoint
 * (/dev/cu.usbmodem105 on the host). That becomes the file-transfer
 * channel for pulling session .dat files off /lfs.
 */
&uart1 {
	status = "okay";
};
